{
    "name": "@lazycaptcha/vue",
    "version": "0.1.0",
    "description": "Vue 3 component for LazyCaptcha — privacy-friendly, self-hostable CAPTCHA. Drop-in alternative to hCaptcha and reCAPTCHA.",
    "keywords": ["vue", "vue3", "captcha", "lazycaptcha", "bot-protection", "hcaptcha-alternative"],
    "license": "MIT",
    "homepage": "https://lazycaptcha.com",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yourusername/lazycaptcha-vue.git"
    },
    "bugs": {
        "url": "https://github.com/yourusername/lazycaptcha-vue/issues"
    },
    "type": "module",
    "main": "./dist/lazycaptcha-vue.umd.cjs",
    "module": "./dist/lazycaptcha-vue.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/lazycaptcha-vue.js",
            "require": "./dist/lazycaptcha-vue.umd.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "vite build && vue-tsc --emitDeclarationOnly -p tsconfig.build.json",
        "dev": "vite",
        "typecheck": "vue-tsc --noEmit",
        "test": "vitest run"
    },
    "peerDependencies": {
        "vue": "^3.3.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "@vue/test-utils": "^2.4.0",
        "@vue/tsconfig": "^0.5.0",
        "jsdom": "^24.0.0",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vitest": "^1.2.0",
        "vue": "^3.4.0",
        "vue-tsc": "^2.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
